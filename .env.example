# TrustScope — example environment.
# Nothing here is required to read reports for repos already in the OpenSSF dataset.
# Copy to `.env.local` and fill only what you need. Never commit real secrets.

# GitHub token for on-demand Scorecard runs + GitHub API (avoids rate limits).
# Locally you can use: GITHUB_AUTH_TOKEN=$(gh auth token)
GITHUB_AUTH_TOKEN=

# Scorecard runner: auto (default) · fastpath · docker · binary
SCORECARD_RUNNER=auto
# Which runner `auto` uses on a fast-path miss: docker (default) · binary
SCORECARD_ONDEMAND=docker
# Path to the `scorecard` binary / the Docker image (only if you override the runner).
SCORECARD_BIN=
SCORECARD_IMAGE=

# Report store: file (default, persistent) · memory
REPORT_STORE=file

# GitHub OAuth App — optional one-click "file as yourself" issue filing (Auth.js).
# The credential-free fallbacks (Copy-Markdown / pre-filled issue) work without these.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_SECRET=
